# ═══════════════════════════════════════════════════════════════════════════════
# L9 SEO BOT - Environment Configuration (v2.0 — @quantum-l9/llm-router powered)
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=l9admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=l9_seo_bot
DATABASE_URL=postgres://l9admin:CHANGE_ME_STRONG_PASSWORD@postgres:5432/l9_seo_bot

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── ClickHouse (PostHog) ─────────────────────────────────────────────────────
CLICKHOUSE_USER=posthog
CLICKHOUSE_PASSWORD=CHANGE_ME_CLICKHOUSE_PASSWORD

# ─── PostHog ──────────────────────────────────────────────────────────────────
POSTHOG_SECRET_KEY=CHANGE_ME_RANDOM_SECRET_KEY
POSTHOG_SITE_URL=http://your-server-ip:8000
POSTHOG_API_URL=http://posthog:8000
POSTHOG_PERSONAL_API_KEY=phx_YOUR_POSTHOG_PERSONAL_API_KEY

# ─── DataForSEO (SERP Intelligence + Backlinks) ──────────────────────────────
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password

# ─── Google APIs ──────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=./config/google-service-account.json
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://your-site.com

# ─── PageSpeed Insights ───────────────────────────────────────────────────────
PAGESPEED_API_KEY=your_google_pagespeed_api_key

# ─── LLM — @quantum-l9/llm-router (Multi-Provider, Task-Based Routing) ──────────────
# Two API keys give you access to ALL models:
#   OpenRouter → GPT-4o, GPT-4o-mini, Claude Sonnet/Opus/Haiku, Gemini Flash/Pro, O1, O3
#   Perplexity → Sonar, Sonar Pro, Sonar Reasoning, Sonar Deep Research
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
PERPLEXITY_API_KEY=pplx-your_perplexity_key

# ─── Cross-repo handoff auth ─────────────────────────────────────────────────
# Shared secret the Website Factory presents (Bearer token) to
# POST /api/clients/register. Must equal Website-Bot's SEO_BOT_API_KEY.
# Leave unset to keep the route open (not recommended in production).
SEO_BOT_API_KEY=

# ─── Budget — Surge-Aware Model ──────────────────────────────────────────────
# The router downgrades models when budget is tight — it NEVER kills a task.
# Per-client monthly budget (dollars)
DEFAULT_CLIENT_MONTHLY_BUDGET=200.00
# Weekly soft target (Mon-Fri normal operations)
DEFAULT_CLIENT_WEEKLY_TARGET=50.00
# Weekly hard ceiling (safety net — allows surge if week was quiet)
DEFAULT_CLIENT_WEEKLY_CEILING=100.00
# Global hard ceiling across ALL clients (monthly)
GLOBAL_MONTHLY_HARD_CEILING=2000.00
# Surge threshold: if week spend < this % of target by Thursday, allow burst
SURGE_THRESHOLD=0.6

# ─── Execution Policy ────────────────────────────────────────────────────────
# Maximum autonomy: only 'critical' actions require approval.
# Options: 'critical' (max autonomy) | 'high' (high+irreversible also queues)
REQUIRE_APPROVAL_ONLY_FOR=critical
AUTO_EXECUTE_THRESHOLD=high

# ─── Email Outreach ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
OUTREACH_FROM_EMAIL=outreach@yourdomain.com
OUTREACH_FROM_NAME=Your Agency Name

# ─── Hunter.io (Email Discovery) ─────────────────────────────────────────────
HUNTER_API_KEY=your_hunter_io_api_key

# ─── Citation Services ────────────────────────────────────────────────────────
BRIGHTLOCAL_API_KEY=your_brightlocal_api_key

# ─── Bot Configuration ────────────────────────────────────────────────────────
BOT_PORT=3100
BOT_LOG_LEVEL=info
BOT_TIMEZONE=America/New_York

# ─── Operator Notifications ───────────────────────────────────────────────────
# Weekly report: TO = domain owner (from client config), CC = operator
OPERATOR_EMAIL=you@yourdomain.com
OPERATOR_CC_EMAIL=ib@quantumaipartners.com
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
