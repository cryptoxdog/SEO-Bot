{
  "name": "l9-seo-bot",
  "version": "2.0.0",
  "type": "module",
  "description": "L9 Autonomous SEO Maintenance Bot - Enterprise-grade, multi-tenant SEO optimization engine with @quantum-l9/llm-router",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "test": "vitest",
    "migrate": "tsx src/core/database/migrate.ts",
    "seed": "tsx src/core/database/seed.ts",
    "add-client": "tsx scripts/add-client.ts",
    "verify:preflight": "tsx -e \"require('./src/core/config.ts')\"",
    "verify:source": "test -f src/index.ts && test -f src/core/config.ts",
    "verify:build": "npm run build && test -f dist/index.js",
    "verify:db": "tsx src/core/database/migrate.ts --check",
    "verify:all": "npm run verify:preflight && npm run verify:source && npm run verify:build"
  },
  "dependencies": {
    "@quantum-l9/llm-router": "^1.0.0",
    "@infisical/sdk": "^5.0.2",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/formbody": "^7.4.0",
    "bullmq": "^5.0.0",
    "cron": "^3.1.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.0",
    "openai": "^4.70.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "posthog-node": "^4.3.0",
    "zod": "^3.23.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.11.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "drizzle-kit": "^0.28.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
